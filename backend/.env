# ── MongoDB ──────────────────────────────────────
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/dsa_tracker

# MongoDB Atlas (cloud) - replace with your connection string
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dsa_tracker?retryWrites=true&w=majority

# ── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT Auth (for multi-user support) ─────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d

# ── CORS ──────────────────────────────────────────
# Frontend URL (for production set to your deployed domain)
FRONTEND_URL=http://localhost:3000
